<% pubs = dataset.publications_for_term(term) %>
<% official = term.official_concept || {} %>
<% official_urn = official["source"] %>
<% official_role = G18::Vocabulary.role(official_urn) %>
<% official_text = official["definition_text"] %>
<%
   if term.undefined?
     match_status, match_status_label = "notinviml", "Not in VIM/VIML"
   elsif official_role == :current
     match_status, match_status_label = "full", "Full match — latest #{official['edition_label']}"
   elsif official_role
     match_status, match_status_label = "outdated", "Outdated — #{official['edition_label']} (superseded)"
   else
     match_status, match_status_label = "unattrib", "Match (unattributed)"
   end
%>
<section class="page-head">
  <div class="breadcrumb">
    <a href="<%= rel_root %>index.html">Registry</a> /
    <a href="<%= rel_root %>terms/index.html">Terms</a> /
    <span><%= h term.name %></span>
  </div>
  <h1><%= h term.name %></h1>
  <p class="lede">
    <%= kind_badge(term) %>
    <span class="match-status match-status-<%= match_status %>"><%= h match_status_label %></span>
    G 18 #<%= h term.identifier %> · <%= pubs.size %> publication instance<%= pubs.size == 1 ? '' : 's' %>
  </p>
</section>

<aside class="legend">
  <h3>How to read this page</h3>
  <div class="legend-row">
    <span class="legend-label">VIM:</span>
    <span class="viml-ref vim-current">VIM 2012<span class="viml-latest-badge">Latest</span></span>
    <span class="viml-ref vim-prior">VIM 2010, 2007</span>
    <span class="viml-ref vim-legacy">VIM 1993</span>
  </div>
  <div class="legend-row">
    <span class="legend-label">VIML:</span>
    <span class="viml-ref viml-current">VIML 2022<span class="viml-latest-badge">Latest</span></span>
    <span class="viml-ref viml-prior">VIML 2013, 2000</span>
    <span class="viml-ref viml-legacy">VIML 1968</span>
  </div>
  <p style="margin: 0.5em 0 0; font-size: 0.85em; color: var(--gray-text);">
    Authoritative definitions form the baseline against which OIML publication definitions are compared. Newer editions take precedence; older ones are shown faded and may have been superseded.
  </p>
</aside>

<section class="card">
  <h2>Authoritative definition</h2>

  <% if term.defined? && official.any? %>
    <% confidence = G18::Vocabulary.confidence_class(official_urn) || "" %>
    <div class="authority-defn <%= confidence %>">
      <div class="authority-defn-head">
        <span class="<%= confidence %>">
          <%= h official["edition_label"] || official_urn %>
          <% if G18::Vocabulary.current?(official_urn) %><span class="viml-latest-badge">Latest</span><% end %>
        </span>
        · concept <strong>#<%= h official["id"] %></strong>
        <% if official["url"] %>
          · <a class="external" href="<%= h official["url"] %>">view ↗</a>
        <% end %>
      </div>
      <% if official_text && !official_text.empty? %>
        <p class="authority-defn-body"><%= h official_text %></p>
      <% else %>
        <p class="muted" style="margin: 0.3em 0;">Definition text unavailable for this edition.</p>
      <% end %>
    </div>

    <% if G18::Vocabulary.superseded?(official_urn) %>
      <% latest_label = G18::Vocabulary.vocab(official_urn) == :vim ? "VIM 2012" : "VIML 2022" %>
      <div class="admonition warn">
        <strong>Outdated reference:</strong> This term cites <%= h official["edition_label"] %>, which has been superseded. The latest authoritative edition of the same vocabulary is <strong><%= latest_label %></strong> — editors should re-check whether the term still appears there with the same or a revised definition.
      </div>
    <% end %>
  <% elsif term.defined? %>
    <p class="muted">Marked as <%= h term.kind %> but no concept reference found.</p>
  <% else %>
    <div class="admonition danger">
      <strong>Not in VIM or VIML.</strong> This term has no authoritative definition in either OIML vocabulary. Its definition is observed only in OIML publications listed below — treat with caution, since there is no canonical baseline to compare against.
    </div>
  <% end %>

  <% if term.related.any? %>
    <h3>Related VIM/VIML references</h3>
    <ul class="related-list">
      <% term.related.each do |edge| %>
        <% ref = edge["ref"] || {} %>
        <% urn = ref["source"] %>
        <% conf = G18::Vocabulary.confidence_class(urn) || "" %>
        <% text = ref["definition_text"] %>
        <% url = ref["url"] || (urn && ref["id"] ? G18::Migration.vocab_concept_url(urn, ref["id"]) : nil) %>
        <li>
          <span class="<%= conf %>">
            <%= h ref["edition_label"] || urn %>
            <% if G18::Vocabulary.current?(urn) %><span class="viml-latest-badge">Latest</span><% end %>
          </span>
          · concept <strong>#<%= h ref["id"] %></strong>
          <% if url %>
            <a class="external" href="<%= h url %>">view ↗</a>
          <% end %>
          <% if text && !text.empty? %>
            <div class="authority-defn-body" style="margin-top: 0.4em; font-size: 0.92em;"><%= h text %></div>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% end %>
</section>

<%
  # Build the list of suggested actions based on term state. The actions are
  # ordered by priority: outdated references > no VIM/VIML > divergent > pending.
  actions = []
  if term.defined? && G18::Vocabulary.superseded?(official_urn)
    latest_label = G18::Vocabulary.vocab(official_urn) == :vim ? "VIM 2012" : "VIML 2022"
    actions << {
      priority: "high",
      text: "Verify this term still appears in #{latest_label}. The current authoritative edition may use a different definition.",
      link: "https://oimlsmart.github.io/vocab/#{G18::Vocabulary.vocab(official_urn) == :vim ? 'vim-2012' : 'viml-2022'}/concept/#{official['id']}",
      label: "View latest #{latest_label} entry",
    }
  end
  if term.undefined?
    actions << {
      priority: "high",
      text: "This term has no authoritative definition in VIM or VIML. Confirm whether it should be added to a future VIM/VIML revision.",
      link: "https://github.com/oimlsmart/vocab/tree/main/datasets/vim-2012",
      label: "Open VIM 2012 dataset",
    }
  end
  if term.diverges? && term.distinct_definitions.size > 1
    actions << {
      priority: "medium",
      text: "#{term.distinct_definitions.size} distinct definitions exist across this term's publications. Decide whether they should converge on a single harmonised definition in the 202X edition.",
      link: "#{rel_root}harmonization.html",
      label: "Open harmonisation worklist",
    }
  end
  if term.consistency_counts["ko"].to_i > 0
    actions << {
      priority: "high",
      text: "#{term.consistency_counts['ko']} publication#{term.consistency_counts['ko'].to_i > 1 ? 's' : ''} substantively diverge from the official baseline. Review and update those Recommendations.",
      link: nil,
      label: nil,
    }
  end
  if term.consistency_counts["partial"].to_i > 0
    actions << {
      priority: "low",
      text: "#{term.consistency_counts['partial']} publication#{term.consistency_counts['partial'].to_i > 1 ? 's' : ''} partially diverge from the official baseline (missing nuance or dropping a clause).",
      link: nil,
      label: nil,
    }
  end
  if term.consistency_counts.keys.all? { |k| k == "pending" }
    actions << {
      priority: "low",
      text: "Consistency has not been assessed for this term yet. Run <code>scripts/check_consistency.rb</code> locally.",
      link: nil,
      label: nil,
    }
  end
  if term.publications.size >= 5
    actions << {
      priority: "info",
      text: "This term appears in #{term.publications.size} OIML publications — high harmonisation value.",
      link: nil,
      label: nil,
    }
  end
%>

<% if actions.any? %>
<section class="card">
  <h2>Suggested actions for TC 1 / Vocabularies</h2>
  <ol class="actions-list">
    <% actions.each do |a| %>
      <li class="action action-<%= a[:priority] %>">
        <span class="action-pill action-pill-<%= a[:priority] %>"><%= a[:priority].upcase %></span>
        <span class="action-text"><%= a[:text].respond_to?(:gsub) ? a[:text].gsub(/<\/?\w+>/, '') : a[:text] %></span>
        <% if a[:link] && a[:label] %>
          · <a href="<%= a[:link] %>"><%= h a[:label] %></a>
        <% end %>
      </li>
    <% end %>
  </ol>
</section>
<% end %>

<section class="card">
  <h2>Consistency</h2>
  <p>
    <% if term.consistency_counts.keys.all? { |k| k == "pending" } %>
      <span class="badge badge-pending">Not yet assessed</span>
      Run <code>scripts/check_consistency.rb</code> to compare each publication's definition against the official one.
    <% else %>
      <span class="badge"><%= h term.consistency_badge %></span>
    <% end %>
  </p>
  <% if term.diverges? %>
    <p class="warn">⚠ <%= term.distinct_definitions.size %> distinct definitions across this term's publications.</p>
  <% end %>
</section>

<section class="card">
  <div class="card-head">
    <h2>Publication instances</h2>
    <div class="pub-controls">
      <label class="inline-check">
        <input type="checkbox" id="only-divergent" onchange="toggleRows()">
        Show only divergent definitions
      </label>
      <span class="edition-filter">
        Show editions:
        <% (term.editions_present || []).sort.each do |ed| %>
          <label class="inline-check edition-toggle-label">
            <input type="checkbox" class="edition-toggle" data-edition="<%= h ed %>" checked onchange="toggleEditions()">
            <span class="edition-pill edition-<%= h ed.downcase %>"><%= h ed %></span>
          </label>
        <% end %>
      </span>
    </div>
  </div>
  <table class="pubs-table">
    <thead>
      <tr>
        <th>Ed.</th>
        <th>Year</th>
        <th>Publication</th>
        <th>TC/SC</th>
        <th>Clause</th>
        <th>Definition</th>
        <th>Consistency</th>
      </tr>
    </thead>
    <tbody>
    <% pubs.each_with_index do |p, idx| %>
      <% pub = dataset.publication_by_id[p["publication_id"]] %>
      <% defn = (p["definition"] || "").strip %>
      <% canonical_def = term.distinct_definitions.first %>
      <% divergent = term.diverges? && defn != canonical_def %>
      <% edition = p["edition"] || "—" %>
      <tr class="pub-row <%= divergent ? 'row-divergent' : '' %>" data-divergent="<%= divergent ? 1 : 0 %>" data-edition="<%= h edition %>">
        <td>
          <span class="edition-pill edition-<%= edition.downcase.gsub(/[^a-z0-9]/, '') %>"><%= h edition %></span>
        </td>
        <td class="num"><%= h p["year"] || "—" %></td>
        <td>
          <a href="<%= rel_root %><%= pub&.path || '#' %>"><%= h p["publication"] %></a>
          <div class="g18-ref">G 18 #<%= h p["g18_entry"] %></div>
          <% if pub&.link %>
            <a class="pdf-link" href="<%= h pub.link %>">PDF ↗</a>
          <% end %>
        </td>
        <td>
          <% if pub&.attributed? %>
            <a href="<%= rel_root %><%= G18::Site::TcSc.slugify(pub.tc_sc) == '' ? 'tc/index.html' : "tc/#{G18::Site::TcSc.slugify(pub.tc_sc)}.html" %>"><%= h pub.tc_sc %></a>
          <% else %>
            <span class="muted">—</span>
          <% end %>
        </td>
        <td class="num"><%= h p["clause"] || "—" %></td>
        <td class="definition">
          <div class="def-text"><%= h defn.empty? ? "(no definition recorded)" : defn %></div>
          <% if p["notes"] && !p["notes"].empty? %>
            <div class="def-notes">Notes: <%= h p["notes"].join("; ") %></div>
          <% end %>
          <% if p["related"] && !p["related"].empty? %>
            <div class="def-edges">
              Cross-refs:
              <% p["related"].each do |e| %>
                <% r = e["ref"] || {} %>
                <% rurn = r["source"] %>
                <% rconf = G18::Vocabulary.confidence_class(rurn) %>
                <code class="<%= rconf %>"><%= h r["edition_label"] || rurn %>/#<%= h r["id"] %></code>
              <% end %>
            </div>
          <% end %>
        </td>
        <td><span class="<%= consistency_badge_class(p["consistency"]) %>"><%= h p["consistency"] || "pending" %></span></td>
      </tr>
    <% end %>
    </tbody>
  </table>
</section>

<script>
function toggleRows() {
  var only = document.getElementById('only-divergent').checked;
  document.querySelectorAll('.pub-row').forEach(function(r) {
    if (only && r.dataset.divergent !== '1') r.style.display = 'none';
    else r.style.display = '';
  });
}
function toggleEditions() {
  var enabled = new Set();
  document.querySelectorAll('.edition-toggle').forEach(function(cb) {
    if (cb.checked) enabled.add(cb.dataset.edition);
  });
  document.querySelectorAll('.pub-row').forEach(function(r) {
    if (enabled.size === 0 || enabled.has(r.dataset.edition)) {
      r.style.display = '';
    } else {
      r.style.display = 'none';
    }
  });
}
// Tag each row with its edition so toggleEditions can find it.
document.addEventListener('DOMContentLoaded', function() {
  document.querySelectorAll('.pub-row').forEach(function(r) {
    var pill = r.querySelector('.edition-pill');
    if (pill) {
      var m = pill.textContent.trim();
      r.dataset.edition = m;
    }
  });
});
</script>
