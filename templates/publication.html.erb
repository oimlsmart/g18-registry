<section class="page-head">
  <div class="breadcrumb">
    <a href="<%= rel_root %>index.html">Registry</a> /
    <a href="<%= rel_root %>publications/index.html">Publications</a> /
    <span><%= h pub.reference %></span>
  </div>
  <h1><%= h pub.reference %></h1>
  <p class="lede">
    <%= h pub.year || "Year unknown" %> ·
    <% if pub.attributed? %>
      <a href="<%= rel_root %>tc/<%= h G18::Site::TcSc.slugify(pub.tc_sc) %>.html"><%= h pub.tc_sc %></a>
    <% else %>
      <span class="muted">TC/SC unattributed</span>
    <% end %>
    <% if pub.notes && !pub.notes.empty? %>
      · <em><%= h pub.notes %></em>
    <% end %>
  </p>
  <% if pub.link %>
  <p><a class="external" href="<%= h pub.link %>">View publication PDF ↗</a></p>
  <% end %>
</section>

<% terms = dataset.terms_for_publication(pub.id) %>

<section class="card">
  <h2>Terms defined in this publication (<%= terms.size %>)</h2>
  <% if terms.any? %>
  <table class="pub-terms-table">
    <thead>
      <tr>
        <th>Term</th>
        <th>Vocabulary</th>
        <th>Clause</th>
        <th>Definition (verbatim)</th>
        <th>Consistency</th>
      </tr>
    </thead>
    <tbody>
    <% terms.each do |t| %>
      <% instance = t.publications.find { |p| p["publication_id"] == pub.id } %>
      <tr>
        <td><a href="<%= rel_root %><%= t.path %>"><%= h t.name %></a></td>
        <td><%= kind_badge(t) %></td>
        <td class="num"><%= h instance&.dig("clause") || "—" %></td>
        <td class="definition">
          <div class="def-text"><%= h (instance&.dig("definition") || "").strip %></div>
          <% if instance && instance["notes"] && !instance["notes"].empty? %>
            <div class="def-notes">Notes: <%= h instance["notes"].join("; ") %></div>
          <% end %>
        </td>
        <td><span class="<%= consistency_badge_class(instance&.dig("consistency")) %>"><%= h instance&.dig("consistency") || "pending" %></span></td>
      </tr>
    <% end %>
    </tbody>
  </table>
  <% else %>
  <p class="muted">No terms recorded for this publication (data integrity issue?).</p>
  <% end %>
</section>
