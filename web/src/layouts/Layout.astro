---
import "../styles/global.css";

const base = import.meta.env.BASE_URL;
const { pathname } = Astro.url;
const currentPath = pathname.replace(base, "/").replace(/\/$/, "");

function isActive(href: string): boolean {
  const target = href.replace(/\/$/, "");
  if (target === "") return currentPath === "/" || currentPath === "";
  return currentPath === target || currentPath.startsWith(target + "/");
}

const primaryNav = [
  { href: "concepts/", label: "Concepts" },
  { href: "publications/", label: "Publications" },
  { href: "tc/", label: "TC / SC" },
];

const analysisNav = [
  { href: "analysis/actions/", label: "Suggested actions" },
  { href: "analysis/gaps/", label: "Gaps" },
  { href: "tc/", label: "By TC / SC" },
  { href: "publications/", label: "By Publication" },
  { href: "analysis/designations/", label: "By Designation" },
];

const g18Nav = [
  { href: "g18/conflicts/", label: "Conflicts" },
  { href: "g18/editions/", label: "Editions" },
];

const activeAnalysis = analysisNav.find(n => isActive(n.href));
const activeG18 = g18Nav.find(n => isActive(n.href));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>OIML Terminology Harmonization</title>
    <link rel="icon" href={`${base}favicon.ico`} />
    <meta name="description" content="OIML Terminology Harmonization — harmonise, validate, and align terminology across OIML publications." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT,WONK@0,9..144,300..700,0..100,0..1;1,9..144,300..700,0..100,0..1&family=Hanken+Grotesk:ital,wght@0,300..700;1,300..600&family=JetBrains+Mono:wght@400;500;600&display=swap" />
    <!-- Prevent flash-of-wrong-theme: apply stored theme before paint -->
    <script is:inline>
      (function () {
        var theme = localStorage.getItem("theme");
        if (!theme) {
          theme = matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
        }
        document.documentElement.dataset.theme = theme;
      })();
    </script>
  </head>
  <body>
    <header class="sticky top-0 z-30 bg-paper-soft/95 backdrop-blur-sm border-b border-rule">
      <div class="mx-auto max-w-[1080px] flex items-center justify-between gap-4 px-6 max-sm:px-4 h-16">
        <a class="flex items-center gap-3 no-underline text-ink hover:no-underline group" href={base}>
          <img src={`${base}oiml-logo.svg`} alt="OIML" class="logo-light block h-7 w-auto shrink-0 transition-transform group-hover:scale-[1.03]" width="28" height="24" />
          <img src={`${base}oiml-logo-dark.svg`} alt="OIML" class="logo-dark block h-7 w-auto shrink-0 transition-transform group-hover:scale-[1.03]" width="28" height="24" />
          <span style="font-family: var(--font-display); font-weight: 500; font-size: 1.125rem; letter-spacing: -0.02em; color: var(--color-ink); line-height: 1.2;">OIML Terminology Harmonization</span>
        </a>

        <div class="flex items-center gap-2">
          <!-- Mobile hamburger -->
          <button
            class="md:hidden flex flex-col justify-center items-center gap-[3px] bg-transparent border-0 p-2 w-9 h-9 cursor-pointer rounded hover:bg-rule-soft"
            aria-label="Toggle navigation menu"
            id="menu-toggle"
          >
            <span class="block h-[1.5px] w-5 bg-ink rounded-full"></span>
            <span class="block h-[1.5px] w-5 bg-ink rounded-full"></span>
            <span class="block h-[1.5px] w-5 bg-ink rounded-full"></span>
          </button>

          <!-- Desktop nav + More dropdown -->
          <nav class="hidden md:flex items-center text-[13px]" aria-label="Primary">
            {primaryNav.map((n) => (
              <a
                class:list={["px-2.5 py-1.5 rounded transition-colors no-underline font-medium whitespace-nowrap",
                  isActive(n.href) ? "bg-accent-tint text-accent" : "text-ink-soft hover:text-accent hover:bg-accent-tint"]}
                href={`${base}${n.href}`}
              >{n.label}</a>
            ))}

            <!-- Analysis dropdown -->
            <div class="relative" id="analysis-dropdown">
              <button
                type="button"
                class:list={["px-2.5 py-1.5 rounded transition-colors font-medium flex items-center gap-1",
                  activeAnalysis ? "bg-accent-tint text-accent" : "text-ink-soft hover:text-accent hover:bg-accent-tint"]}
                aria-haspopup="true"
                id="analysis-toggle"
              >
                Analysis
                {activeAnalysis && <span class="nav-subactive">{activeAnalysis.label}</span>}
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9" />
                </svg>
              </button>
              <div class="more-dropdown" id="analysis-menu" style="display:none" role="menu">
                {analysisNav.map((n) => (
                  <a
                    class:list={["more-dropdown-item", { "more-dropdown-item-active": isActive(n.href) }]}
                    role="menuitem"
                    href={`${base}${n.href}`}
                  >{n.label}</a>
                ))}
              </div>
            </div>

            <!-- G18 dropdown -->
            <div class="relative" id="g18-dropdown">
              <button
                type="button"
                class:list={["px-2.5 py-1.5 rounded transition-colors font-medium flex items-center gap-1",
                  activeG18 ? "bg-accent-tint text-accent" : "text-ink-soft hover:text-accent hover:bg-accent-tint"]}
                aria-haspopup="true"
                id="g18-toggle"
              >
                G18
                {activeG18 && <span class="nav-subactive">{activeG18.label}</span>}
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9" />
                </svg>
              </button>
              <div class="more-dropdown" id="g18-menu" style="display:none" role="menu">
                {g18Nav.map((n) => (
                  <a
                    class:list={["more-dropdown-item", { "more-dropdown-item-active": isActive(n.href) }]}
                    role="menuitem"
                    href={`${base}${n.href}`}
                  >{n.label}</a>
                ))}
              </div>
            </div>
          </nav>

          <!-- Help (?) + Theme toggle (rightmost) -->
          <a href={`${base}how-to-use/`} class="help-link" aria-label="How to use" title="How to use">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10" /><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" /><line x1="12" y1="17" x2="12.01" y2="17" />
            </svg>
          </a>
          <button
            type="button"
            class="theme-toggle"
            aria-label="Toggle light/dark theme"
            id="theme-toggle"
          >
            <svg class="icon-dark" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="4" /><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
            </svg>
            <svg class="icon-light" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile dropdown -->
      <nav class="md:hidden absolute left-0 right-0 top-full bg-paper-soft border-b border-rule shadow-lg px-4 py-3 z-40 max-h-[calc(100vh-64px)] overflow-y-auto hidden" aria-label="Primary mobile" id="mobile-nav">
        {primaryNav.map((n) => (
          <a class="block px-3 py-2.5 text-[15px] text-ink rounded hover:bg-accent-tint hover:text-accent hover:no-underline font-medium" href={`${base}${n.href}`}>{n.label}</a>
        ))}
        <div class="h-px bg-rule-soft my-2 mx-1"></div>
        <span class="block px-3 py-1 text-[10.5px] uppercase tracking-[0.12em] font-semibold text-ink-muted">Analysis</span>
        {analysisNav.map((n) => (
          <a class="block px-3 py-2.5 text-[14px] text-ink-soft rounded hover:bg-accent-tint hover:text-accent hover:no-underline font-medium" href={`${base}${n.href}`}>{n.label}</a>
        ))}
        <div class="h-px bg-rule-soft my-2 mx-1"></div>
        <span class="block px-3 py-1 text-[10.5px] uppercase tracking-[0.12em] font-semibold text-ink-muted">G18</span>
        {g18Nav.map((n) => (
          <a class="block px-3 py-2.5 text-[14px] text-ink-soft rounded hover:bg-accent-tint hover:text-accent hover:no-underline font-medium" href={`${base}${n.href}`}>{n.label}</a>
        ))}
      </nav>
    </header>

    <main class="mx-auto max-w-[1080px] px-6 max-sm:px-4 py-10 max-sm:py-6 min-h-[70vh]">
      <slot />
    </main>

    <footer class="bg-oiml-brand-900 text-oiml-brand-200 mt-20 py-10 text-[13px]">
      <div class="mx-auto max-w-[1080px] px-6 max-sm:px-4 grid grid-cols-1 md:grid-cols-[auto_1fr_auto] gap-6 items-start">
        <div class="flex items-center gap-3">
          <img src={`${base}oiml-logo.svg`} alt="OIML" class="logo-light block h-8 w-auto shrink-0" width="32" height="28" />
          <img src={`${base}oiml-logo-dark.svg`} alt="OIML" class="logo-dark block h-8 w-auto shrink-0" width="32" height="28" />
        </div>
        <div class="space-y-1.5">
          <div class="text-white" style="font-family: var(--font-display); font-weight: 500; font-size: 1.05rem; letter-spacing: -0.015em;">OIML Terminology Harmonization</div>
          <div>
            Source: <a class="text-oiml-brand-300 hover:text-white underline" href="https://github.com/oimlsmart/vocab/tree/main/datasets/g18-2010">oimlsmart/vocab</a>
            · VIM/VIML: <a class="text-oiml-brand-300 hover:text-white underline" href="https://www.oimlsmart.org/vocab/">www.oimlsmart.org/vocab</a>
          </div>
        </div>
        <div class="md:text-right md:border-l md:border-oiml-brand-700 md:pl-6">
          <div class="text-white font-semibold">OIML SMART</div>
          <div>Digital service by <a class="text-oiml-brand-300 hover:text-white underline font-medium" href="https://www.ribose.com">Ribose</a></div>
        </div>
      </div>
    </footer>

    <style is:global>
      /* Theme toggle + dropdown styles (was in App.vue <style>) */
      .theme-toggle {
        appearance: none;
        background: transparent;
        border: 0;
        color: var(--color-ink-soft);
        width: 36px;
        height: 36px;
        border-radius: 4px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background 0.15s, color 0.15s;
      }
      .theme-toggle:hover {
        background: var(--color-paper-tint);
        color: var(--color-accent);
      }
      .help-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 4px;
        color: var(--color-ink-soft);
        transition: background 0.15s, color 0.15s;
      }
      .help-link:hover {
        background: var(--color-paper-tint);
        color: var(--color-accent);
      }
      /* Logo swap via CSS — no JS needed */
      .logo-dark { display: none; }
      [data-theme="dark"] .logo-light { display: none; }
      [data-theme="dark"] .logo-dark { display: block; }
      /* Theme toggle icon swap */
      .icon-light { display: none; }
      [data-theme="dark"] .icon-dark { display: none; }
      [data-theme="dark"] .icon-light { display: block; }

      /* Subnav active indicator — shows current page in dropdown */
      .nav-subactive {
        font-size: 0.68rem;
        font-weight: 500;
        opacity: 0.7;
        margin-left: 0.2em;
      }

      .more-dropdown {
        position: absolute;
        top: 100%;
        right: 0;
        min-width: 12em;
        margin-top: 0.3em;
        background: var(--color-paper-soft);
        border: 1px solid var(--color-rule);
        border-radius: 4px;
        box-shadow: 0 4px 12px -4px rgba(10, 22, 40, 0.12);
        padding: 0.4em 0;
        z-index: 50;
        display: flex;
        flex-direction: column;
      }
      .more-dropdown-item {
        display: block;
        padding: 0.5em 0.9em;
        color: var(--color-ink-soft);
        font-size: 0.92rem;
        text-decoration: none;
        white-space: nowrap;
        transition: background 0.1s, color 0.1s;
      }
      .more-dropdown-item:hover {
        background: var(--color-accent-tint);
        color: var(--color-accent);
        text-decoration: none;
      }
      .more-dropdown-item-active {
        background: var(--color-accent-tint);
        color: var(--color-accent);
        font-weight: 600;
      }
    </style>

    <script>
      // Theme toggle
      document.getElementById("theme-toggle")?.addEventListener("click", () => {
        const current = document.documentElement.dataset.theme || "light";
        const next = current === "dark" ? "light" : "dark";
        document.documentElement.dataset.theme = next;
        localStorage.setItem("theme", next);
      });

      // Mobile menu toggle
      const menuToggle = document.getElementById("menu-toggle");
      const mobileNav = document.getElementById("mobile-nav");
      menuToggle?.addEventListener("click", () => {
        mobileNav?.classList.toggle("hidden");
      });
      // Close mobile nav on link click
      mobileNav?.querySelectorAll("a").forEach((a) => {
        a.addEventListener("click", () => mobileNav.classList.add("hidden"));
      });

      // Dropdown helper: handles click-toggle, outside-click, escape-key
      function setupDropdown(toggleId, menuId, dropdownId) {
        const toggle = document.getElementById(toggleId);
        const menu = document.getElementById(menuId);
        const dropdown = document.getElementById(dropdownId);
        if (!toggle || !menu) return;
        toggle.addEventListener("click", (e) => {
          e.stopPropagation();
          // Close other dropdowns
          document.querySelectorAll(".more-dropdown").forEach(d => { if (d.id !== menuId) d.style.display = "none"; });
          const isHidden = menu.style.display === "none";
          menu.style.display = isHidden ? "flex" : "none";
        });
        document.addEventListener("click", (e) => {
          if (dropdown && !dropdown.contains(e.target)) menu.style.display = "none";
        });
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape") menu.style.display = "none";
        });
      }
      setupDropdown("analysis-toggle", "analysis-menu", "analysis-dropdown");
      setupDropdown("g18-toggle", "g18-menu", "g18-dropdown");
    </script>
  </body>
</html>
