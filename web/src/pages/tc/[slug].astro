---
import Layout from "@/layouts/Layout.astro";
import TcDetailPage from "@/islands/TcDetailPage.vue";
import tc from "@/data/tc.json";
import { slugify } from "@/utils/term-utils";

export function getStaticPaths() {
  return (tc as string[]).map(name => ({
    params: { slug: slugify(name) },
    props: { slug: slugify(name) },
  }));
}

const { slug } = Astro.props;
---
<Layout>
  <TcDetailPage client:only="vue" slug={slug} />
</Layout>
