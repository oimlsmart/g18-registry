---
import Layout from "@/layouts/Layout.astro";
import PublicationDetailPage from "@/islands/PublicationDetailPage.vue";
import publications from "@/data/publications.json";
import { slugify } from "@/utils/term-utils";

export function getStaticPaths() {
  return (publications as any[]).map(p => ({
    params: { slug: slugify(p.id) },
    props: { slug: slugify(p.id) },
  }));
}

const { slug } = Astro.props;
---
<Layout>
  <PublicationDetailPage client:load slug={slug} />
</Layout>
