# Local build output
_site/
.cache/

# Editor / OS
.DS_Store
*.swp

# Node
node_modules/
web/dist/
web/node_modules/
web/.vite-ssg-temp/

# Ruby bundler local config (we commit Gemfile + Gemfile.lock)
.bundle/

# ── Derived data ────────────────────────────────────────────────────────
# All three are regenerated in CI from vocab + the committed LLM cache:
#   cache/consistency.jsonl  → data/*.yaml (migrate + apply-cached) → web/src/data/*.json
# The LLM cache is the ONLY non-regeneratable artifact (needs API key) so
# it is committed. Everything else is derived and gitignored.

# Per-term YAML, migrated from oimlsmart/vocab at build time
/data/

# Frontend JSON, exported from data/
/web/src/data/

# Keep the LLM consistency cache committed (no API key in CI).
!cache/
!cache/consistency.jsonl
scripts/*.bak
*.bak
